{
  "name": "instaforge-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram to Cloudflare Worker to GitHub Actions pipeline for AI frame editing and video generation.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "job:generate": "tsx src/jobs/generateSceneJob.ts",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "basic-ftp": "^6.0.1",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.0",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.16.1"
  }
}
