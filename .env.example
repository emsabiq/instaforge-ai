# Cloudflare Worker secrets/vars
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_WORKFLOW_FILE=generate-video.yml
GITHUB_BRANCH=main

# GitHub Actions secrets
MAGNIFIC_API_KEY=
MAGNIFIC_BASE_URL=https://api.magnific.ai
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_BASE_URL=

# Upload target
UPLOAD_DRIVER=auto
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_DIR=/public_html/telegram-ai-frame
PUBLIC_BASE_URL=https://example.com/telegram-ai-frame

# Optional FTP mirror values. The app uses SFTP_* first, then FTP_* as fallback.
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=

# Local runtime
SESSION_DIR=data/sessions
OUTPUT_DIR=generated
FFMPEG_PATH=ffmpeg
